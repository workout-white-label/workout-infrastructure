# Copy to production.tfvars and adjust. production.tfvars is gitignored.
#
# Shared platform only. Per-microservice infrastructure is applied from
# src/stack/ecs-service (git submodule in each app repository).
#
# terraform init -backend-config=backend.hcl
# terraform apply -var-file=production.tfvars

aws_region   = "eu-west-1"
project_name = "workout"
environment  = "production"

# manage_github_oidc_provider = false  # if OIDC provider already exists

github_ecs_service_terraform_repositories = [
  "workout-white-label/workout-user-manager",
]

# Private EC2 for SSM port forwarding (IDE → RDS). No SSH port open.
# enable_ssm_bastion = true
# ssm_bastion_postgres_egress_cidr_blocks = ["10.0.0.0/16"]

tags = {
  Project     = "workout"
  Environment = "production"
  Layer       = "platform"
}
