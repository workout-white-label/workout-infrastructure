# Copy to production.tfvars and adjust. production.tfvars is gitignored.
#
# Creates VPC + PostgreSQL RDS for workout-user-manager in one apply.
# Schema (users table, etc.) is created by Flyway in workout-user-manager on startup.
#
# IMPORTANT: aws_region cannot be changed after the first apply without destroying all
# resources in the old region first. If you started in us-east-1, destroy there before
# switching to eu-west-1 (see stack comments in main.tf).

aws_region   = "eu-west-1"
project_name = "workout"
environment  = "production"

# db_name     = "user_manager"
# db_username = "user_manager"
# engine_version = "16"

tags = {
  Project     = "workout"
  Environment = "production"
  Service     = "user-manager"
}
