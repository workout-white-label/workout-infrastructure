# Copy to production.tfvars and adjust. production.tfvars is gitignored.

aws_region   = "us-east-1"
project_name = "workout"
environment  = "production"

# Optional: customise Cognito. Add or remove clients as needed.
# clients = {
#   app  = { generate_secret = false }   # e.g. mobile
#   web  = { generate_secret = false }   # e.g. SPA
#   api  = { generate_secret = true }    # e.g. backend
# }
# user_pool_name        = "workout-production-users"
# cognito_domain_prefix = "workout-production-auth"
# password_policy_min_length = 12

tags = {
  Project     = "workout"
  Environment = "production"
}
